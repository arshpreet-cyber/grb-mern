generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int
  content    String
  authorName String
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  MANAGER
  SEO
  DEVELOPER
  TESTER
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String?
  phone     String?
  role      Role     @default(USER)
  status    String   @default("passive")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  tickets   Ticket[]

  @@index([createdAt])
}

model Order {
  id                     Int           @id @default(autoincrement())
  isOrderApi             Int           @default(1) @map("is_order_api")
  orderNumber            String?       @map("order_number")
  userId                 Int?          @map("user_id")
  paymentId              String?       @map("payment_id")
  subscriptionId         String?       @map("subscription_id")
  rzpaySubscriptionId    String?       @map("rzpay_subscription_id")
  itemName               String?       @map("item_name")
  itemId                 String?       @map("item_id")
  isRecurring            Int?          @map("is_recurring")
  zohoInvoiceId          String?       @map("zoho_invoice_id")
  zohoRecurringInvoiceId String?       @map("zoho_recurring_invoice_id")
  firstName              String?       @map("first_name")
  lastName               String?       @map("last_name")
  currency               String?       @map("currency")
  symbol                 String?       @map("symbol")
  amount                 Float?
  bitcoinAmount          String?       @map("bitcoin_amount")
  bitcoinsReceived       String?       @map("bitcoins_received")
  couponId               String?       @map("coupon_id")
  coupon                 String?
  couponDiscount         Int?          @map("coupon_discount")
  email                  String?
  billingCountry         String?       @map("billing_country")
  billingStateCode       String?       @map("billing_state_code")
  billingCity            String?       @map("billing_city")
  billingStreet          String?       @map("billing_street")
  billingZip             String?       @map("billing_zip")
  shippingStateCode      String?       @map("shipping_state_code")
  shippingCountry        String?       @map("shipping_country")
  shippingCity           String?       @map("shipping_city")
  shippingStreet         String?       @map("shipping_street")
  shippingZip            String?       @map("shipping_zip")
  payUrl                 String?       @db.Text @map("pay_url")
  subscriptionUrl        String?       @db.Text @map("subscription_url")
  sessionData            String?       @db.Text @map("session_data")
  status                 String        @default("1")
  detailsFilled          Boolean       @default(false) @map("details_filled")
  detailsFilledAt        DateTime?     @map("details_filled_at")
  reminderEmailSent      Boolean       @default(false) @map("reminder_email_sent")
  bitcoinAddress         String?       @db.Text @map("bitcoin_address")
  binancePrepayId        String?       @db.Text @map("binance_prepayId")
  expiry                 Float?        @map("expiry")
  paymentStatus          String?       @default("1") @map("payment_status")
  paymentMethod          String?       @default("1") @map("payment_method")
  workStatus             Int?          @map("work_status")
  assignedUserId         String?       @db.Text @map("assigned_user_id")
  duedate                DateTime?
  paymentDate            DateTime?     @map("payment_date")
  stripeSessionId        String?       @db.Text @map("stripe_session_id")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  completedOn            DateTime?     @map("completed_on")
  deletedAt              DateTime?     @map("deleted_at")
  assignedDate           DateTime?     @map("assigned_date")
  purchaseType           String?       @map("purchase_type")
  isRenewal              Boolean       @default(false) @map("is_renewal")
  isAutoEntry            Boolean?      @default(false) @map("is_auto_entry")
  parentOrderId          Int?          @map("parent_order_id")
  paidCount              Int?          @map("paid_count")
  tokenCode              String?       @map("token_code")
  notes                  String?       @db.Text @map("notes")
  user                   User?         @relation(fields: [userId], references: [id])
  orderDetails           OrderDetail[]

  @@index([createdAt])
  @@index([paymentStatus, deletedAt])
  @@index([orderNumber])
  @@map("orders")
}

model OrderDetail {
  id          Int       @id @default(autoincrement())
  orderId     Int       @map("order_id")
  order       Order     @relation(fields: [orderId], references: [id])
  itemName    String?   @map("item_name")
  bannerTitle String?   @map("banner_title")
  itemId      String?   @map("item_id")
  amount      Float?
  quantity    Int?
  reviewData  String?   @db.Text @map("review_data")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  productType String?   @default("1") @map("product_type")

  @@index([itemName])
  @@map("order_details")
}

model Ticket {
  id             Int             @id @default(autoincrement())
  ticketNumber   String?         @db.VarChar(50) @map("ticket_number")
  userId         Int             @map("user_id")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo     String?         @db.VarChar(30) @map("assigned_to")
  name           String?         @db.VarChar(225)
  email          String?         @db.VarChar(225)
  phone          String?         @db.VarChar(255)
  subject        String?
  query          String?
  media          String?
  title          String          @default("")
  ticketId       String          @unique @default(cuid()) @db.VarChar(255) @map("ticket_id")
  byAdmin        Int?            @default(1) @map("by_admin")
  ticketType     Int?            @map("ticket_type")
  status         String          @default("Open")
  readStatus     Int?            @default(1) @db.SmallInt @map("read_status")
  repliedStatus  Int?            @db.SmallInt @map("replied_status")
  userReadStatus Int?            @db.SmallInt @map("user_read_status")
  zohoTicketId   String?         @db.VarChar(255) @map("zohoTicketId")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  repliedAt      DateTime?       @db.Timestamp(6) @map("replied_at")
  lastThreadId   String?         @db.VarChar(255) @map("last_thread_id")
  adminReplyAt   DateTime?       @db.Timestamp(6) @map("admin_reply_at")
  deleted_at     DateTime?       @db.Timestamp(6)
  threads        TicketThread[]

  @@index([createdAt])
  @@map("Ticket")
}

model TicketThread {
  id         Int      @id @default(autoincrement())
  ticketId   String   @db.VarChar(255)
  ticket     Ticket   @relation(fields: [ticketId], references: [ticketId], onDelete: Cascade)
  agentId    String?  @db.VarChar(255)
  content    String?  @db.Text
  media      String?  @db.VarChar(255)
  direction  String   @default("1") @db.VarChar(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@map("TicketThread")
}

model Revenue {
  id        Int      @id @default(autoincrement())
  month     String
  year      Int
  today     Float    @default(0)
  monthly   Float    @default(0)
  yearly    Float    @default(0)
  allTime   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  status          String   @default("Draft")
  titleImage      String?
  opengraphImage  String?
  canonicalLink   String?
  robotsText      String   @default("index, follow")
  keywords        String?
  metaTitle       String?
  metaDescription String?
  inSitemap       Boolean  @default(true)
  schemaCode      String?
  headerScript    String?
  bodyScript      String?
  footerScript    String?
  sections        Json     @default("[]")
  draftSections   Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum YesNo {
  YES
  NO
}

enum PaymentType {
  ONE_TIME
  RECURRING
}

enum ProductType {
  SERVICE
  GOODS
}

enum CatType {
  REVIEWS
  SEO
  SMM
  ACCOUNTS
  GBP
}

enum ProductStatus {
  PUBLISH
  DRAFT
  UNUSED
}

model Product {
  id                Int            @id @default(autoincrement())
  userId            String?        @map("userId")
  formId            Int?           @map("formId")
  isAged            YesNo          @default(NO) @map("isAged")
  isZohoItem        YesNo?         @map("isZohoItem")
  isFreeProduct     Int?           @map("isFreeProduct")
  zohoItemId        String?        @map("zohoItemId")
  bannerTitle       String?        @map("bannerTitle")
  title             String?
  content           String?        @db.Text
  categoryId        String?        @map("categoryId")
  subcategoryId     String?        @map("subcategoryId")
  accountTag        String?        @db.VarChar(30) @map("accountTag")
  stock             String?
  replacementPolicy String?        @map("replacementPolicy")
  minimumQuantity   Int            @default(1) @map("minimumQuantity")
  seeDetailLink     String?        @map("seeDetailLink")
  isMultiplePrice   Int?           @map("isMultiplePrice")
  price             String?
  dropdownPrice     String?        @db.Text @map("dropdownPrice")
  isMonthly         Int?           @map("isMonthly")
  colorCode         String?        @map("colorCode")
  slug              String?
  keywords          String?
  metaDescription   String?        @db.Text @map("metaDescription")
  metaTitle         String?        @db.Text @map("metaTitle")
  canonicalLink     String?        @db.Text @map("canonicalLink")
  media             String?
  allowMultiple     YesNo?         @map("allowMultiple")
  paymentType       PaymentType?   @map("paymentType")
  productType       ProductType?   @map("productType")
  catType           CatType?       @map("catType")
  formAttached      String?        @db.VarChar(30) @map("formAttached")
  priority          Int?           @default(1000)
  status            ProductStatus?
  platformRange     Int?           @map("platformRange")
  createdAt         DateTime?      @default(now()) @map("createdAt")
  updatedAt         DateTime?      @updatedAt @map("updatedAt")
  deletedAt         DateTime?      @map("deletedAt")

  @@map("Product")
}

enum AttachmentType {
  BLOG
  BANNER
  CATEGORY
  TESTIMONIAL
  USER
  PAGE
  PORTFOLIO
  SERVICE
  LOGO
}

model Coupon {
  id           Int       @id @default(autoincrement())
  code         String?
  discount     String?
  discountType String?   @map("discount_type")
  discountOn   String?   @map("discount_on")
  quantity     String?
  expiry       String?
  discountFor  Int       @default(1) @map("discount_for")
  meta         String?
  status       String?
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@map("coupons")
}

model Attachment {
  id        Int             @id @default(autoincrement())
  mediaUrl  String?
  alt       String?
  isTitle   String?
  mediaType String?
  type      AttachmentType
  createdAt DateTime?       @default(now())
  updatedAt DateTime?       @updatedAt
  deletedAt DateTime?
}

model Blog {
  id               BigInt   @id @default(autoincrement())
  user_id          String?
  category         String?  @db.Text
  tag              String?  @db.Text
  title            String?
  excerpt          String?  @db.Text
  content          String?  @db.Text
  category_id      String?
  subcategory_id   String?
  slug             String?  @unique
  keywords         String?
  meta_description String?  @db.Text
  meta_title       String?  @db.Text
  canonical_link   String?  @db.Text
  media            String?
  author           String?
  about_author     String?  @db.Text
  status           Int      @default(2)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  deleted_at       DateTime?
}

model Redirect {
  id        Int      @id @default(autoincrement())
  fromPath  String   @unique
  toPath    String
  type      Int      @default(301)
  active    Boolean  @default(true)
  hits      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model subscribers {
  id            BigInt   @id @default(autoincrement())
  email         String   @unique
  phone         String?
  user_ip       String?
  user_browser  String?
  status        Int      @default(1)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  deleted_at    DateTime?
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailOtp {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
